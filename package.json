{
  "name": "gx-campaign-hero-assessment",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:assessment": "vitest run src/core-ui/organisms/CampaignHero.test.tsx src/assessment-contract.test.ts",
    "test:browser": "playwright test",
    "assessment:check": "npm run lint && npm run typecheck && npm run test:unit && npm run test:browser && npm run build && npm run build:storybook",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@oxc-parser/binding-darwin-arm64": "^0.127.0",
    "@playwright/test": "^1.60.0",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "storybook": "^10.4.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
